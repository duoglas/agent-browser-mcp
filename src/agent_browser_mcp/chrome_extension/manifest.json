{
  "manifest_version": 3,
  "name": "TMWD CDP Bridge",
  "version": "2.1",
  "description": "CDP bridge for agent browser automation (per-tab CSP scoping, WS keepalive)",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab",
    "debugger",
    "scripting",
    "alarms",
    "declarativeNetRequest",
    "management"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TMWD CDP Bridge"
  }
}